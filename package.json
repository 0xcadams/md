{
  "name": "peruse",
  "version": "0.2.0",
  "private": true,
  "description": "minimal server to view markdown and code",
  "license": "Unlicense",
  "type": "module",
  "scripts": {
    "binary": "bun run build && bun run scripts/build-binary.ts",
    "build": "bun run generate:demo-git && bun run build:assets && bun run build:server && bun run check",
    "build:assets": "bun run scripts/build-assets.ts",
    "build:server": "bun run scripts/build-server.ts",
    "check": "bun run generate:demo-git --check && tsc --noEmit && oxlint . && oxfmt --check .",
    "dev": "bun run generate:demo-git && bun run build:assets && bun --watch src/index.ts",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "generate:demo-git": "bun run scripts/generate-demo-git.ts",
    "lint": "oxlint .",
    "start": "bun src/index.ts",
    "test": "bun run generate:demo-git --check && bun run build:assets && bun test"
  },
  "dependencies": {
    "@shikijs/rehype": "4.3.1",
    "hono": "4.12.30",
    "mime-types": "3.0.2",
    "rehype-autolink-headings": "7.1.0",
    "rehype-raw": "7.0.0",
    "rehype-sanitize": "6.0.0",
    "rehype-slug": "6.0.0",
    "rehype-stringify": "10.0.1",
    "remark-gfm": "4.0.1",
    "remark-parse": "11.0.0",
    "remark-rehype": "11.1.2",
    "shiki": "4.3.1",
    "unified": "11.0.5",
    "unist-util-visit": "5.1.0",
    "vfile": "6.0.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/hast": "3.0.5",
    "@types/mdast": "4.0.4",
    "@types/mime-types": "3.0.1",
    "@types/node": "26.1.1",
    "github-markdown-css": "5.9.0",
    "mermaid": "11.16.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22"
  }
}
