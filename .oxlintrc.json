{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "perf": "warn",
    "suspicious": "error"
  },
  "ignorePatterns": ["demo-files/**", "dist/**", "node_modules/**", "public/assets/**"],
  "options": {
    "denyWarnings": true,
    "reportUnusedDisableDirectives": "error"
  },
  "plugins": ["import", "typescript", "unicorn"]
}
