{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "bracketSpacing": false,
  "ignorePatterns": [
    ".git/**",
    "dist/**",
    "demo-git/generated.json",
    "node_modules/**",
    "public/assets/**",
    "server.js",
    "vercel.json"
  ],
  "printWidth": 100,
  "proseWrap": "preserve",
  "semi": true,
  "sortImports": true
}
